bindkey -M vicmd '^xp' history-beginning-search-backward
bindkey -M vicmd '^xn' history-beginning-search-forward
bindkey -M viins '^O' copy-prev-shell-word
bindkey '^P' push-line-or-edit # push current command line into a buffer, for later use
bindkey '^a' beginning-of-line
bindkey '^e' end-of-line

# Kill only the trailing path component when editing paths like /a/b/c
function backward-kill-path-component() {
  # Remove slash from WORDCHARS so backward-kill-word stops at the previous /
  local WORDCHARS=${WORDCHARS//\/}
  zle backward-kill-word
}
zle -N backward-kill-path-component
bindkey '^w' backward-kill-path-component

bindkey '^y' yank
