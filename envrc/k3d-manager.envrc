#!/usr/bin/env bash
# ~/.zsh/envrc/k3d-manager.envrc
# k3d-manager specific direnv config

source_up

export PATH=$PATH:$(pwd)/bin
git config core.hooksPath scripts/hooks

# Agent lint config — maps lib-foundation generic vars to k3d-manager specifics
export AGENT_LINT_GATE_VAR=K3DM_ENABLE_AI
export AGENT_LINT_AI_FUNC=_k3d_manager_copilot
