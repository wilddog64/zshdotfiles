#!/usr/bin/env bash
# ~/.zsh/envrc/personal.envrc
# Common setup for all personal projects under ~/src/gitrepo/personal/

if [[ "$(uname -s)" == "Darwin" ]]; then
    ~/.local/bin/sync-claude ~/.claude || true
    ~/.local/bin/sync-gemini ~/.gemini || true
else
    ~/.local/bin/sync-gemini ~/.gemini || true
fi

# Shared Codex skills (clipboard helper, etc.)
export CODEX_SKILLS="$HOME/src/gitrepo/personal/codex-skill/skills"
if [[ -d "$CODEX_SKILLS" ]]; then
    export PATH="$PATH:$CODEX_SKILLS"
fi
