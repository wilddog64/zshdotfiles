#!/usr/bin/env bash
# ~/.zsh/envrc/personal.envrc
# Common setup for all personal projects under ~/src/gitrepo/personal/
layout python3

if [[ "$(uname -s)" == "Darwin" ]]; then
    ~/.local/bin/sync-claude ~/.claude || true
    ~/.local/bin/sync-gemini ~/.gemini || true
    ~/.local/bin/sync-codex ~/.codex|| true
else
    ~/.local/bin/sync-gemini ~/.gemini || true
fi

# Shared Codex skills (clipboard helper, etc.)
export CODEX_SKILLS="$HOME/src/gitrepo/personal/codex-skill/skills"
if [[ -d "$CODEX_SKILLS" ]]; then
    export PATH="$PATH:$CODEX_SKILLS"
fi

# for claude, set the max thinking tokens to 8192 and disable adaptive thinking
export MAX_THINKING_TOKENS=8192
export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=1
export CLAUDE_CODE_EFFORT=normal
export CLAUDE_CODE_DISABLE_1M_CONTEXT=1
